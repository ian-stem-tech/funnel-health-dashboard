MAILCHIMP_API_KEY=your-api-key-here
MAILCHIMP_SERVER_PREFIX=us4

IG_HANDLE=stemplayer
TIKTOK_HANDLE=stemplayer

# TikTok Display API v2 (https://developers.tiktok.com/doc/display-api-get-started/)
# Required for fetching video metrics via the official API.
# 1. Create an app at https://developers.tiktok.com/
# 2. Enable Display API with video.list and user.info.basic scopes
# 3. Complete OAuth flow to get access_token and refresh_token
# 4. Access token expires in 24h; refresh token lasts 365 days
#    (the script auto-refreshes using the refresh token)
TIKTOK_CLIENT_KEY=your-client-key
TIKTOK_CLIENT_SECRET=your-client-secret
TIKTOK_ACCESS_TOKEN=your-access-token
TIKTOK_REFRESH_TOKEN=your-refresh-token
